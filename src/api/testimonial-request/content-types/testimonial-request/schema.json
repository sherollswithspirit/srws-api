{
  "kind": "collectionType",
  "collectionName": "testimonial_requests",
  "info": {
    "singularName": "testimonial-request",
    "pluralName": "testimonial-requests",
    "displayName": "Testimonial Request",
    "description": "Single-use tokenized invitations for customers to submit a testimonial"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "recipientName": {
      "type": "string",
      "required": true
    },
    "recipientEmail": {
      "type": "email",
      "required": true
    },
    "token": {
      "type": "string",
      "unique": true
    },
    "requestStatus": {
      "type": "enumeration",
      "enum": ["pending", "completed", "expired"],
      "default": "pending"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "sentAt": {
      "type": "datetime"
    },
    "usedAt": {
      "type": "datetime"
    },
    "testimonial": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::testimonial.testimonial"
    }
  }
}
